TASK_ADMIN_PASSWORD=change-me
MARKETING_BOT_ENABLED=0

# Persistent storage. Set this on the server to a directory outside the git checkout.
# The SQLite database, marketing uploads, Telegram session and bot config live here.
OGARNIEMY_DATA_DIR=/var/lib/ogarniemy

# Optional explicit database path. Usually OGARNIEMY_DATA_DIR is enough.
# TASK_DB_PATH=/var/lib/ogarniemy/server.db

# Telegram / Facebook integrations.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
ADMIN_TELEGRAM_IDS=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=ogarniemy-verify
